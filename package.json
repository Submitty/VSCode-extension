{
  "name": "submittyextension",
  "displayName": "SubmittyExtension",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "Submitty",
        "properties": {
          "submitty.baseUrl": {
            "type": "string",
            "default": "",
            "description": "The base URL for the Submitty API (e.g., https://example.submitty.edu)",
            "markdownDescription": "The base URL for the Submitty API (e.g., `https://example.submitty.edu`)"
          }
        }
      }
    ],
    "commands": [
      {
        "command": "submitty.setUserId",
        "title": "Set Submitty User ID"
      },
      {
        "command": "submitty.setPassword",
        "title": "Set Submitty Password"
      },
      {
        "command": "submitty.login",
        "title": "Log in to Submitty"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "submittySidebar",
          "title": "Submitty",
          "icon": "media/duck.png"
        }
      ]
    },
    "views": {
      "submittySidebar": [
        {
          "type": "webview",
          "id": "submittyWebview",
          "name": "Submitty",
          "icon": "media/duck.png"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rimraf out",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "keytar": "^7.9.0"
  }
}
